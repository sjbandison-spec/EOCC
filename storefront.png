
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&family=League+Spartan:wght@700;800;900&display=swap');

:root {
  --navy:#082044;
  --navy-2:#0c2b57;
  --orange:#f06b12;
  --orange-2:#ff7a1a;
  --gold:#e0a51d;
  --gold-2:#ffc234;
  --cream:#fff8ed;
  --white:#fff;
  --ink:#13253f;
  --muted:#647084;
  --line:rgba(8,32,68,.10);
  --shadow:0 12px 28px rgba(8,32,68,.10);
  --shadow-lg:0 22px 48px rgba(8,32,68,.16);
  --max:1240px;
}

* { box-sizing:border-box; }
html { scroll-behavior:smooth; }
body { margin:0; font-family:Inter,Arial,sans-serif; color:var(--ink); background:#fff; }
a { color:inherit; }
img { max-width:100%; display:block; }
.container { width:min(var(--max),calc(100% - 32px)); margin:0 auto; }

.site-header {
  position:sticky;
  top:0;
  z-index:90;
  background:rgba(255,255,255,.97);
  backdrop-filter:blur(14px);
  border-bottom:1px solid rgba(8,32,68,.06);
}
.header-row { display:flex; align-items:center; justify-content:space-between; gap:22px; min-height:110px; }
.brand { display:flex; align-items:center; text-decoration:none; }
.brand img { width:152px; height:auto; }
.site-nav { display:flex; align-items:center; gap:30px; font-size:14px; font-weight:800; }
.site-nav a { text-decoration:none; position:relative; white-space:nowrap; }
.site-nav a.active::after,.site-nav a:hover::after {
  content:""; position:absolute; left:0; right:0; bottom:-12px; height:3px; background:var(--orange); border-radius:999px;
}
.join-btn { padding:14px 22px; border-radius:6px; background:var(--orange); color:#fff!important; box-shadow:0 10px 22px rgba(240,107,18,.24); }
.join-btn::after { display:none!important; }
.nav-toggle { display:none; border:0; background:transparent; font-size:28px; color:var(--navy); }

.hero { padding:0 0 10px; background:#fff; overflow:hidden; }
.hero-grid { display:grid; grid-template-columns:1fr 1.2fr; align-items:stretch; min-height:500px; }
.hero-copy {
  padding:54px 18px 40px 0;
  display:flex;
  flex-direction:column;
  justify-content:center;
  position:relative;
  z-index:2;
  background:linear-gradient(90deg,#fff 0%,#fff 70%,rgba(255,255,255,.92) 86%,rgba(255,255,255,0) 100%);
}
.hero h1 {
  margin:0 0 18px;
  font-family:'League Spartan',Inter,sans-serif;
  font-size:clamp(58px,6.4vw,92px);
  line-height:.90;
  letter-spacing:-2px;
  text-transform:uppercase;
  color:var(--navy);
}
.hero h1 span { color:var(--orange); }
.hero p { margin:0 0 24px; max-width:570px; font-size:17px; line-height:1.55; color:#334155; font-weight:550; }
.location { display:flex; gap:14px; align-items:flex-start; margin-bottom:24px; max-width:500px; font-weight:800; color:#2f4059; font-size:17px; line-height:1.35; }
.pin { flex:0 0 26px; width:26px; height:26px; position:relative; border-radius:50% 50% 50% 0; background:var(--orange); transform:rotate(-45deg); margin-top:3px; }
.pin::after { content:""; position:absolute; width:10px; height:10px; border-radius:50%; background:#fff; left:8px; top:8px; }
.hero-actions { display:flex; gap:22px; flex-wrap:wrap; }
.btn {
  min-height:54px;
  padding:14px 28px;
  border-radius:7px;
  display:inline-flex;
  align-items:center;
  justify-content:center;
  gap:16px;
  text-decoration:none;
  font-size:15px;
  font-weight:900;
  transition:transform .18s ease, box-shadow .18s ease;
}
.btn:hover { transform:translateY(-2px); }
.btn-primary { background:var(--navy); color:#fff; box-shadow:0 14px 28px rgba(8,32,68,.16); }
.btn-secondary { background:#fff; color:var(--navy); border:2px solid #f2a36a; }
.btn-orange { background:var(--orange); color:#fff; box-shadow:0 14px 28px rgba(240,107,18,.24); }
.btn-outline-light { background:transparent; color:#fff; border:2px solid var(--gold-2); }
.btn .arrow { font-size:22px; line-height:1; }
.hero-image { position:relative; overflow:hidden; border-bottom-left-radius:10px; background:#f4f4f4; }
.hero-image img { width:100%; height:100%; object-fit:cover; }

.ticker { background:var(--navy); color:#fff; overflow:hidden; border-top:1px solid rgba(255,255,255,.08); border-bottom:1px solid rgba(255,255,255,.08); }
.ticker-track {
  display:flex;
  gap:28px;
  min-width:max-content;
  padding:12px 0;
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
  white-space:nowrap;
  letter-spacing:.2px;
  animation:ticker 30s linear infinite;
}
.ticker-track span { display:inline-flex; align-items:center; gap:28px; opacity:.98; }
.ticker-track span::before { content:"★"; color:var(--gold-2); }
@keyframes ticker { from {transform:translateX(0)} to {transform:translateX(-50%)} }

.image-strip { display:grid; grid-template-columns:repeat(4,1fr); gap:6px; padding:6px 0 16px; background:#fff; }
.image-card { position:relative; min-height:244px; border-radius:6px; overflow:hidden; box-shadow:var(--shadow); }
.image-card img { width:100%; height:100%; object-fit:cover; }
.image-card::after { content:""; position:absolute; left:0; right:0; bottom:0; height:78px; background:linear-gradient(180deg,rgba(8,32,68,0) 0%,rgba(8,32,68,.95) 100%); }
.caption { position:absolute; left:0; right:0; bottom:0; z-index:2; display:flex; align-items:center; gap:12px; padding:12px 14px; color:#fff; background:rgba(8,32,68,.96); }
.cap-ico { width:42px; height:42px; border-radius:50%; border:2px solid var(--orange); display:grid; place-items:center; color:var(--orange); font-size:20px; font-weight:900; flex:0 0 42px; }
.caption strong { display:block; font-size:14px; line-height:1.1; text-transform:uppercase; letter-spacing:.2px; }
.caption small { display:block; font-size:12px; line-height:1.2; margin-top:4px; opacity:.98; }

.section { padding:44px 0; }
.page-hero { background:var(--cream); padding:56px 0 42px; border-bottom:1px solid var(--line); }
.page-hero h1, .section-title h1 {
  margin:0 0 12px;
  font-family:'League Spartan';
  font-size:clamp(46px,5.4vw,78px);
  line-height:.90;
  color:var(--navy);
  text-transform:uppercase;
  letter-spacing:-1.5px;
}
.page-hero p, .section-title p { max-width:780px; color:#304257; font-size:17px; line-height:1.55; margin:0; }
.eyebrow { font-size:13px; font-weight:900; text-transform:uppercase; color:var(--orange); letter-spacing:.2px; }
h2 {
  margin:10px 0 12px;
  font-family:'League Spartan',Inter,sans-serif;
  font-size:clamp(32px,3.2vw,50px);
  line-height:.95;
  letter-spacing:-1px;
  text-transform:uppercase;
  color:var(--navy);
}
.split { display:grid; grid-template-columns:1fr 1.8fr; gap:22px; align-items:stretch; }
.stats { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; }
.stat, .resource-card, .member-card, .leader-card, .brand-card, .sponsor-card {
  background:#fff;
  border:1px solid rgba(8,32,68,.08);
  border-radius:12px;
  box-shadow:var(--shadow);
}
.stat { padding:20px 18px 18px; text-align:center; min-height:214px; display:flex; flex-direction:column; align-items:center; justify-content:flex-start; }
.icon { width:64px; height:64px; border-radius:50%; display:grid; place-items:center; color:#fff; background:var(--navy); font-size:30px; font-weight:900; margin-bottom:12px; }
.stat:nth-child(even) .icon, .resource-card:nth-child(even) .icon { background:var(--orange); }
.stat strong { display:block; font-family:'League Spartan'; font-size:58px; line-height:.9; color:var(--navy); letter-spacing:-1px; }
.stat b { display:block; margin-top:4px; font-size:20px; line-height:1; text-transform:uppercase; color:var(--navy); }
.stat small { display:block; margin-top:10px; font-size:15px; line-height:1.35; color:#3d4f64; }

.sponsors { margin:14px auto 16px; background:linear-gradient(90deg,#07244a,#0b2d5d,#07244a); color:#fff; border-radius:4px; display:grid; grid-template-columns:1.1fr repeat(3,1fr); align-items:center; gap:18px; padding:18px 20px; box-shadow:var(--shadow-lg); }
.sponsors h3 { margin:0; font-size:20px; line-height:1.05; text-transform:uppercase; font-weight:900; }
.sponsors h3 span { display:block; font-size:14px; color:var(--gold-2); margin-bottom:4px; }
.sponsor-logo { font-family:'League Spartan',Inter,sans-serif; font-size:36px; letter-spacing:.2px; line-height:.9; text-align:center; }
.sponsor-logo small { display:block; font-family:Inter,sans-serif; font-size:12px; letter-spacing:2px; text-transform:uppercase; margin-top:8px; opacity:.95; }

.double-panels { display:grid; grid-template-columns:1fr 1.35fr; gap:18px; padding-bottom:18px; }
.panel { background:#fff; border:1px solid rgba(8,32,68,.08); border-radius:10px; box-shadow:var(--shadow); padding:16px; }
.panel-header { display:flex; justify-content:space-between; align-items:center; gap:12px; margin-bottom:14px; }
.panel-header h3 { margin:0; font-size:20px; line-height:1; text-transform:uppercase; color:var(--orange); font-weight:900; }
.panel-header a { text-decoration:none; font-size:12px; font-weight:900; color:var(--navy); text-transform:uppercase; }

.featured-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
.feature-card { min-height:140px; border:1px solid rgba(8,32,68,.10); border-radius:10px; padding:16px; background:#fff; }
.feature-card .badge, .member-badge { width:50px; height:50px; border-radius:14px; background:linear-gradient(135deg,var(--gold-2),var(--orange)); display:grid; place-items:center; font-size:16px; font-weight:900; color:var(--navy); margin-bottom:12px; }
.feature-card h4, .member-card h4 { margin:0 0 6px; color:var(--navy); font-size:15px; line-height:1.2; }
.feature-card p, .member-card p { margin:0 0 10px; color:#32475e; font-size:12px; line-height:1.4; }

.leaders-inline { display:grid; grid-template-columns:repeat(5,1fr); gap:10px; }
.leader-inline { display:grid; grid-template-columns:42px 1fr; gap:9px; align-items:center; min-width:0; }
.avatar { width:42px; height:42px; border-radius:50%; object-fit:cover; box-shadow:0 0 0 2px #fff,0 0 0 3px rgba(240,107,18,.30); }
.leader-inline strong { display:block; font-size:12px; color:var(--navy); line-height:1.1; }
.leader-inline span { display:block; font-size:10px; line-height:1.15; color:#31445b; }

.cta-band { background:linear-gradient(90deg,#07244a,#0a2d5d,#07244a); color:#fff; padding:18px 0; margin-top:10px; }
.cta-row { display:grid; grid-template-columns:120px 1fr auto; gap:20px; align-items:center; }
.cta-row img { width:110px; height:auto; }
.cta-copy h2 { margin:0; font-family:'League Spartan'; font-size:52px; line-height:.9; letter-spacing:-1px; text-transform:uppercase; color:#fff; }
.cta-copy h2 span { color:var(--gold-2); }
.cta-copy p { margin:10px 0 0; font-size:17px; opacity:.98; }
.cta-actions { display:flex; gap:16px; flex-wrap:wrap; }

.section-title { margin-bottom:20px; }
.section-title h2 { margin:8px 0 10px; }
.section-alt { background:var(--cream); border-top:1px solid rgba(8,32,68,.08); border-bottom:1px solid rgba(8,32,68,.08); }
.tools { display:grid; grid-template-columns:1fr 250px; gap:12px; margin:20px 0; }
.tools input,.tools select,.contact-form input,.contact-form select,.contact-form textarea { width:100%; padding:14px 15px; border-radius:8px; border:1px solid rgba(8,32,68,.14); font:inherit; background:#fff; }
.member-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:14px; }
.member-card { padding:16px; }
.member-card small { display:block; color:#5c697c; font-size:11px; font-weight:700; line-height:1.3; }

.leadership-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:14px; }
.leader-card { padding:18px; text-align:center; }
.leader-card .avatar { width:72px; height:72px; margin:0 auto 12px; }
.leader-card h4 { margin:0 0 6px; color:var(--navy); font-size:16px; line-height:1.15; }
.leader-card p { margin:0 0 10px; color:var(--orange); font-size:13px; font-weight:800; line-height:1.2; }
.term { display:inline-block; padding:7px 11px; border-radius:999px; background:#f7efe4; color:var(--navy); font-size:11px; font-weight:900; }

.resource-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:16px; }
.resource-card { padding:20px; min-height:180px; }
.resource-card .icon { width:56px; height:56px; font-size:28px; margin-bottom:16px; }
.resource-card h4 { margin:0 0 10px; color:var(--navy); font-size:20px; line-height:1.05; text-transform:uppercase; }
.resource-card p { margin:0; color:#33465d; font-size:14px; line-height:1.5; }

.brand-grid { display:grid; grid-template-columns:.8fr 1.2fr; gap:24px; align-items:start; }
.brand-card { padding:24px; }
.brand-card img { width:100%; max-width:380px; margin:auto; }
.swatches { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-top:20px; }
.swatch { min-height:90px; border-radius:12px; display:flex; align-items:end; padding:12px; font-weight:900; color:#fff; }
.swatch.navy { background:var(--navy); }
.swatch.gold { background:var(--gold); color:var(--navy); }
.swatch.orange { background:var(--orange); }
.swatch.cream { background:var(--cream); color:var(--navy); border:1px solid var(--line); }

.contact-grid { display:grid; grid-template-columns:.9fr 1.1fr; gap:28px; }
.contact-form { background:#fff; border:1px solid rgba(8,32,68,.08); border-radius:12px; box-shadow:var(--shadow); padding:20px; }
.contact-form label { display:block; font-weight:800; margin-bottom:14px; }
.contact-form input,.contact-form select,.contact-form textarea { margin-top:7px; }

.footer { border-top:1px solid rgba(8,32,68,.08); padding:18px 0 26px; background:#fff; }
.footer-row { display:grid; grid-template-columns:1.25fr 1fr 1fr; gap:18px; align-items:center; font-size:14px; font-weight:800; color:var(--navy); }
.footer-row .center,.footer-row .right { text-align:center; }
.footer-row .right a { text-decoration:none; white-space:nowrap; }

@media (max-width:1100px) {
  .site-nav { display:none; position:absolute; top:110px; left:0; right:0; background:#fff; padding:18px 24px; border-bottom:1px solid var(--line); flex-direction:column; align-items:flex-start; gap:18px; }
  .site-nav.open { display:flex; }
  .nav-toggle { display:block; }
  .hero-grid,.split,.double-panels,.cta-row,.footer-row,.brand-grid,.contact-grid { grid-template-columns:1fr; }
  .hero-copy { background:#fff; padding-right:0; }
  .image-strip,.stats,.resource-grid,.member-grid,.leadership-grid { grid-template-columns:repeat(2,1fr); }
  .sponsors { grid-template-columns:1fr; justify-items:center; text-align:center; }
  .leaders-inline { grid-template-columns:repeat(2,1fr); }
  .featured-grid { grid-template-columns:1fr; }
  .tools { grid-template-columns:1fr; }
}
@media (max-width:640px) {
  .container { width:min(100% - 20px,var(--max)); }
  .brand img { width:120px; }
  .hero h1 { font-size:46px; }
  .location { font-size:15px; }
  .hero-actions,.cta-actions { flex-direction:column; }
  .btn { width:100%; }
  .image-strip,.stats,.member-grid,.leaders-inline,.leadership-grid,.resource-grid,.swatches { grid-template-columns:1fr; }
  .section { padding:34px 0; }
  .cta-copy h2 { font-size:40px; }
  .footer-row { grid-template-columns:1fr; text-align:center; }
  .footer-row .center,.footer-row .right { text-align:center; }
}


/* V8 full-complete enhancements */
.about-complete-grid {
  display:grid;
  grid-template-columns: .9fr 1.1fr;
  gap:28px;
  align-items:start;
}
.about-main-card {
  background:#fff;
  border:1px solid rgba(8,32,68,.08);
  border-radius:14px;
  box-shadow:var(--shadow);
  padding:28px;
}
.about-main-card h2 {
  margin-top:0;
}
.about-main-card p {
  color:#304257;
  line-height:1.65;
  font-size:16px;
}
.about-side-stack {
  display:grid;
  gap:16px;
}
.about-feature-card {
  background:linear-gradient(135deg,#fff,#fff7e9);
  border:1px solid rgba(8,32,68,.08);
  border-radius:14px;
  box-shadow:var(--shadow);
  padding:22px;
}
.about-feature-card h3 {
  margin:0 0 10px;
  font-size:24px;
  color:var(--navy);
  text-transform:uppercase;
  font-family:'League Spartan',Inter,sans-serif;
  line-height:.95;
}
.about-feature-card p {
  margin:0;
  color:#304257;
  line-height:1.6;
}
.about-year {
  min-height:150px;
  background:linear-gradient(135deg,var(--navy),#0b2d5d);
  color:#fff;
  border-radius:14px;
  box-shadow:var(--shadow-lg);
  padding:24px;
  display:flex;
  flex-direction:column;
  justify-content:center;
}
.about-year strong {
  display:block;
  font-family:'League Spartan',Inter,sans-serif;
  font-size:72px;
  line-height:.85;
  color:var(--gold-2);
}
.about-year span {
  display:block;
  text-transform:uppercase;
  font-weight:900;
  letter-spacing:.08em;
}
.preview-note {
  background:linear-gradient(90deg,#fff8ed,#ffffff);
  border:1px solid rgba(8,32,68,.08);
  border-radius:12px;
  box-shadow:var(--shadow);
  padding:16px 18px;
  margin:18px 0;
  font-weight:800;
  color:#304257;
}
.page-divider-ticker {
  background:var(--navy);
  color:#fff;
  overflow:hidden;
}
.page-divider-ticker .ticker-track {
  padding:10px 0;
}
.full-preview-anchor {
  scroll-margin-top:120px;
}
@media (max-width:1100px) {
  .about-complete-grid {
    grid-template-columns:1fr;
  }
}


/* V10 final board test refinements */
.leader-card-link,
.leader-link {
  text-decoration:none;
  color:inherit;
  cursor:pointer;
}
.leader-card-link {
  transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;
}
.leader-card-link:hover {
  transform:translateY(-4px);
  box-shadow:0 22px 46px rgba(8,32,68,.16);
  border-color:rgba(240,107,18,.35);
}
.leader-card .avatar,
.leader-inline .avatar {
  object-fit:cover;
  object-position:center top;
  background:#fff8ed;
}
.view-bio {
  display:inline-block;
  margin-top:10px;
  color:var(--orange);
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
}
.leader-email {
  display:block;
  margin-top:8px;
  color:#647084;
  font-weight:800;
  font-size:11px;
  overflow-wrap:anywhere;
}
.bio-grid {
  display:grid;
  grid-template-columns:360px 1fr;
  gap:32px;
  align-items:start;
}
.bio-photo-card,
.bio-content-card,
.bio-inline-card {
  background:#fff;
  border:1px solid rgba(8,32,68,.08);
  border-radius:16px;
  box-shadow:var(--shadow);
}
.bio-photo-card {
  padding:18px;
}
.bio-photo-card img {
  width:100%;
  aspect-ratio:4/5;
  object-fit:cover;
  object-position:center top;
  border-radius:12px;
}
.bio-content-card {
  padding:28px;
}
.bio-content-card h1 {
  margin:0 0 8px;
  font-family:'League Spartan',Inter,sans-serif;
  font-size:clamp(40px,5vw,68px);
  line-height:.9;
  color:var(--navy);
  text-transform:uppercase;
}
.bio-role {
  color:var(--orange);
  font-weight:900;
  text-transform:uppercase;
}
.bio-content-card p,
.bio-inline-card p {
  color:#304257;
  line-height:1.7;
}
.bio-meta {
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin:20px 0;
}
.bio-meta span,
.bio-meta a {
  display:inline-flex;
  align-items:center;
  padding:9px 12px;
  border-radius:999px;
  background:#fff8ed;
  color:var(--navy);
  font-size:13px;
  font-weight:900;
  text-decoration:none;
}
.bio-inline-card {
  display:grid;
  grid-template-columns:170px 1fr;
  gap:18px;
  padding:18px;
  margin-bottom:16px;
  scroll-margin-top:130px;
}
.bio-inline-photo img {
  width:100%;
  aspect-ratio:1/1;
  object-fit:cover;
  object-position:center top;
  border-radius:12px;
}
.bio-inline-card h3 {
  margin:4px 0 4px;
  color:var(--navy);
  font-size:28px;
  line-height:1;
  text-transform:uppercase;
  font-family:'League Spartan',Inter,sans-serif;
}
@media (max-width:820px) {
  .bio-grid,
  .bio-inline-card {
    grid-template-columns:1fr;
  }
  .bio-photo-card,
  .bio-inline-photo {
    max-width:420px;
  }
}


/* V11 board review restoration: browser frame, clickable directors, visible directory */
.browser-frame {
  height: 34px;
  background: linear-gradient(#f7f7f7,#ececec);
  border-bottom: 1px solid #d8d8d8;
  display:flex;
  align-items:center;
  gap:12px;
  padding:0 16px;
  position:sticky;
  top:0;
  z-index:200;
}
.browser-dots {
  display:flex;
  gap:8px;
}
.browser-dots span {
  width:11px;
  height:11px;
  border-radius:50%;
  display:block;
}
.browser-dots span:nth-child(1) { background:#ff5f57; }
.browser-dots span:nth-child(2) { background:#febc2e; }
.browser-dots span:nth-child(3) { background:#28c840; }
.browser-address {
  margin:0 auto;
  height:22px;
  min-width:260px;
  max-width:430px;
  width:44%;
  background:#fff;
  border:1px solid #d9d9d9;
  border-radius:999px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:12px;
  color:#606060;
  font-weight:700;
}
.site-header {
  top:34px;
}
.leader-card-link,
.leader-link {
  text-decoration:none;
  color:inherit;
  cursor:pointer;
}
.leader-card-link {
  transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease;
}
.leader-card-link:hover {
  transform:translateY(-4px);
  box-shadow:0 22px 46px rgba(8,32,68,.16);
  border-color:rgba(240,107,18,.35);
}
.leader-card .avatar,
.leader-inline .avatar {
  object-fit:cover;
  object-position:center top;
  background:#fff8ed;
}
.view-bio {
  display:inline-block;
  margin-top:10px;
  color:var(--orange);
  font-size:12px;
  font-weight:900;
  text-transform:uppercase;
}
.leader-email {
  display:block;
  margin-top:8px;
  color:#647084;
  font-weight:800;
  font-size:11px;
  overflow-wrap:anywhere;
}
.directory-showcase {
  background:var(--cream);
  border-top:1px solid rgba(8,32,68,.08);
  border-bottom:1px solid rgba(8,32,68,.08);
}
.directory-showcase .member-grid {
  max-height:none;
  overflow:visible;
}
.bio-grid {
  display:grid;
  grid-template-columns:360px 1fr;
  gap:32px;
  align-items:start;
}
.bio-photo-card,
.bio-content-card,
.bio-inline-card {
  background:#fff;
  border:1px solid rgba(8,32,68,.08);
  border-radius:16px;
  box-shadow:var(--shadow);
}
.bio-photo-card { padding:18px; }
.bio-photo-card img {
  width:100%;
  aspect-ratio:4/5;
  object-fit:cover;
  object-position:center top;
  border-radius:12px;
}
.bio-content-card { padding:28px; }
.bio-content-card h1 {
  margin:0 0 8px;
  font-family:'League Spartan',Inter,sans-serif;
  font-size:clamp(40px,5vw,68px);
  line-height:.9;
  color:var(--navy);
  text-transform:uppercase;
}
.bio-role {
  color:var(--orange);
  font-weight:900;
  text-transform:uppercase;
}
.bio-content-card p,
.bio-inline-card p { color:#304257; line-height:1.7; }
.bio-meta {
  display:flex;
  flex-wrap:wrap;
  gap:10px;
  margin:20px 0;
}
.bio-meta span,
.bio-meta a {
  display:inline-flex;
  align-items:center;
  padding:9px 12px;
  border-radius:999px;
  background:#fff8ed;
  color:var(--navy);
  font-size:13px;
  font-weight:900;
  text-decoration:none;
}
.bio-inline-card {
  display:grid;
  grid-template-columns:170px 1fr;
  gap:18px;
  padding:18px;
  margin-bottom:16px;
  scroll-margin-top:130px;
}
.bio-inline-photo img {
  width:100%;
  aspect-ratio:1/1;
  object-fit:cover;
  object-position:center top;
  border-radius:12px;
}
.bio-inline-card h3 {
  margin:4px 0 4px;
  color:var(--navy);
  font-size:28px;
  line-height:1;
  text-transform:uppercase;
  font-family:'League Spartan',Inter,sans-serif;
}
@media (max-width:820px) {
  .browser-frame { display:none; }
  .site-header { top:0; }
  .bio-grid,
  .bio-inline-card { grid-template-columns:1fr; }
}


/* V12 full operational review refinements */
.browser-frame {
  height: 34px;
  background: linear-gradient(#f7f7f7,#ececec);
  border-bottom: 1px solid #d8d8d8;
  display:flex;
  align-items:center;
  gap:12px;
  padding:0 16px;
  position:sticky;
  top:0;
  z-index:200;
}
.browser-dots { display:flex; gap:8px; }
.browser-dots span { width:11px; height:11px; border-radius:50%; display:block; }
.browser-dots span:nth-child(1) { background:#ff5f57; }
.browser-dots span:nth-child(2) { background:#febc2e; }
.browser-dots span:nth-child(3) { background:#28c840; }
.browser-address {
  margin:0 auto;
  height:22px;
  min-width:260px;
  max-width:430px;
  width:44%;
  background:#fff;
  border:1px solid #d9d9d9;
  border-radius:999px;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:12px;
  color:#606060;
  font-weight:700;
}
.site-header { top:34px; }
.leader-card-link, .leader-link { text-decoration:none; color:inherit; cursor:pointer; }
.leader-card-link { transition:transform .18s ease, box-shadow .18s ease, border-color .18s ease; }
.leader-card-link:hover { transform:translateY(-4px); box-shadow:0 22px 46px rgba(8,32,68,.16); border-color:rgba(240,107,18,.35); }
.leader-card .avatar, .leader-inline .avatar { object-fit:cover; object-position:center top; background:#fff8ed; }
.view-bio { display:inline-block; margin-top:10px; color:var(--orange); font-size:12px; font-weight:900; text-transform:uppercase; }
.leader-email { display:block; margin-top:8px; color:#647084; font-weight:800; font-size:11px; overflow-wrap:anywhere; }
.directory-showcase { background:var(--cream); border-top:1px solid rgba(8,32,68,.08); border-bottom:1px solid rgba(8,32,68,.08); }
.directory-showcase .member-grid { max-height:none; overflow:visible; }
.bio-grid { display:grid; grid-template-columns:360px 1fr; gap:32px; align-items:start; }
.bio-photo-card, .bio-content-card, .bio-inline-card { background:#fff; border:1px solid rgba(8,32,68,.08); border-radius:16px; box-shadow:var(--shadow); }
.bio-photo-card { padding:18px; }
.bio-photo-card img { width:100%; aspect-ratio:4/5; object-fit:cover; object-position:center top; border-radius:12px; }
.bio-content-card { padding:28px; }
.bio-content-card h1 { margin:0 0 8px; font-family:'League Spartan',Inter,sans-serif; font-size:clamp(40px,5vw,68px); line-height:.9; color:var(--navy); text-transform:uppercase; }
.bio-role { color:var(--orange); font-weight:900; text-transform:uppercase; }
.bio-content-card p, .bio-inline-card p { color:#304257; line-height:1.7; }
.bio-meta { display:flex; flex-wrap:wrap; gap:10px; margin:20px 0; }
.bio-meta span, .bio-meta a { display:inline-flex; align-items:center; padding:9px 12px; border-radius:999px; background:#fff8ed; color:var(--navy); font-size:13px; font-weight:900; text-decoration:none; }
.bio-inline-card { display:grid; grid-template-columns:170px 1fr; gap:18px; padding:18px; margin-bottom:16px; scroll-margin-top:130px; }
.bio-inline-photo img { width:100%; aspect-ratio:1/1; object-fit:cover; object-position:center top; border-radius:12px; }
.bio-inline-card h3 { margin:4px 0 4px; color:var(--navy); font-size:28px; line-height:1; text-transform:uppercase; font-family:'League Spartan',Inter,sans-serif; }
.full-site-banner { background: #fff8ed; border: 1px solid rgba(8,32,68,.10); box-shadow: var(--shadow); border-radius: 12px; padding: 14px 18px; margin: 18px auto; font-weight: 800; color: var(--navy); }
@media (max-width:820px) {
  .browser-frame { display:none; }
  .site-header { top:0; }
  .bio-grid, .bio-inline-card { grid-template-columns:1fr; }
}
